{
  "name": "fflf-extractor",
  "version": "1.0.0",
  "author": "RmaN",
  "description": "FirstFrame LastFrame Extractor — Extract first and last frames from any video format.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:web": "node server.js",
    "build": "electron-builder --win portable",
    "build:win": "electron-builder --win portable",
    "build:linux": "electron-builder --linux AppImage",
    "build:mac": "electron-builder --mac dmg",
    "build:all": "electron-builder --win portable --linux AppImage --mac dmg",
    "commit-build": "node scripts/commit-build.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.fflf.extractor",
    "productName": "FFLF Extractor",
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/ffprobe-static/**/*"
    ],
    "files": [
      "**/*",
      "!server.js",
      "!temp_uploads/**",
      "!nginx.example.conf",
      "!DEPLOY.md"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
